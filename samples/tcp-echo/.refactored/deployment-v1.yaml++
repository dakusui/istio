$extends:
  - shared/deployment-base.yaml++
metadata:
  name: tcp-echo-v1
  labels:
    app: tcp-echo
    version: v1
spec:
  selector:
    matchLabels:
      version: v1
  template:
    metadata:
      labels:
        version: v1
    spec:
      containers:
      - name: tcp-echo
        image: registry.istio.io/release/tcp-echo-server:1.3
        imagePullPolicy: IfNotPresent
        args: ["9000,9001,9002", "one"]
        ports:
        - containerPort: 9000
        - containerPort: 9001
