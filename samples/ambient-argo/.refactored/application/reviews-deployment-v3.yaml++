$extends:
- ../shared/reviews-deployment-base.yaml++
metadata:
  name: reviews-v3
  labels:
    version: v3
spec:
  selector:
    matchLabels:
      version: v3
  template:
    metadata:
      labels:
        version: v3
    spec:
      containers:
      - name: reviews
        image: registry.istio.io/release/examples-bookinfo-reviews-v3:1.18.0
        imagePullPolicy: IfNotPresent
        env:
        - name: LOG_DIR
          value: "/tmp/logs"
        ports:
        - containerPort: 9080
        volumeMounts:
        - name: tmp
          mountPath: /tmp
        - name: wlp-output
          mountPath: /opt/ibm/wlp/output
      volumes:
      - name: wlp-output
        emptyDir: {}
      - name: tmp
        emptyDir: {}
