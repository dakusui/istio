$extends:
- ../shared/argocd-app-ambient-cluster-base.yaml++
metadata:
  name: istio-ztunnel
spec:
  destination:
    namespace: istio-system
  source:
    repoURL: 'https://istio-release.storage.googleapis.com/charts'
    targetRevision: 1.18.5
    chart: ztunnel
    helm:
      valuesObject:
        revision: rapid
