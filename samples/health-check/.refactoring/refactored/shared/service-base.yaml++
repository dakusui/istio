apiVersion: v1
kind: Service
metadata:
  name: "eval:string:refexpr(\"._app\")"
  labels:
    app: "eval:string:refexpr(\"._app\")"
    service: "eval:string:refexpr(\"._app\")"
spec:
  ports:
    - name: http
      port: "eval:number:refexpr(\"._port\")"
  selector:
    app: "eval:string:refexpr(\"._app\")"
