$local:
  AppLabels:
    app: tornado
    version: v1

apiVersion: apps/v1
kind: Deployment
metadata:
  name: tornado
spec:
  replicas: 1
  selector:
    matchLabels:
      $extends:
        - AppLabels
  template:
    metadata:
      labels:
        $extends:
          - AppLabels
    spec:
      containers:
      - name: tornado
        image: docker.io/hiroakis/tornado-websocket-example
        imagePullPolicy: IfNotPresent
        ports:
        - containerPort: 8888
