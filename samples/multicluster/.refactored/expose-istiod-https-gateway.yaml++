$extends:
  - shared/istiod-gateway-base.yaml++
spec:
  servers:
    - port:
        name: https-istiod
        number: 15012
        protocol: https
      tls:
        mode: SIMPLE
        credentialName: "$CREDENTIAL_NAME"
      hosts:
      - "ISTIOD-HOST.DOMAIN"
    - port:
        name: https-istiodwebhook
        number: 15017
        protocol: https
      tls:
        mode: SIMPLE
        credentialName: "$CREDENTIAL_NAME"
      hosts:
      - "ISTIOD-HOST.DOMAIN"
