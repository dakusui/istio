$extends:
  - base-deployment.yaml++
spec:
  template:
    spec:
      containers:
      - name: "eval:string:refexpr(\"._app\")"
        image: "eval:string:bookinfo::bookinfo_image(refexpr(\"._app\"); refexpr(\"._version\"))"
        imagePullPolicy: IfNotPresent
        ports:
        - containerPort: 9080
