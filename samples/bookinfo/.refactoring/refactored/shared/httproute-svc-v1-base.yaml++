apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: "eval:string:refexpr(\"._svc\")"
spec:
  parentRefs:
    - group: ""
      kind: Service
      name: "eval:string:refexpr(\"._svc\")"
      port: 9080
  rules:
    - backendRefs:
        - name: "eval:string:bookinfo::svc_v1(refexpr(\"._svc\"))"
          port: 9080
