apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  name: details
spec:
  hosts:
  - details
  http:
  - fault:
      abort:
        httpStatus: 555
        percentage:
          value: 100
    route:
    - destination:
        host: details
        subset: v1
  - route:
    - destination:
        host: details
        subset: v1
---
$extends:
  - destination-rule-base.yaml++
  - subsets.jq
_app: details
spec:
  subsets:
  - "eval:object:subsets::versioned_subset(\"v1\")"
