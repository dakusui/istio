#!/usr/bin/env bash
# yjoin — join {stem}@{id}.yaml[++] part-files in SRC_DIR into {stem}.yaml in OUT_DIR.
#
# Naming convention:
#   {stem}@{id}.yaml++   → rendered via: jq++ file | yq -y '.'
#   {stem}@{id}.yaml     → rendered via: yq -y '.' file
#   {name}.yaml++        → single-doc passthrough (no grouping)
#
# Files within each stem are sorted lexicographically by identifier, so numeric
# prefixes (01-, 02-, …) are recommended for deterministic ordering.
#
# Usage:
#   yjoin [--out-dir OUT_DIR] [SRC_DIR]
#
# Defaults:
#   SRC_DIR  = current directory
#   OUT_DIR  = SRC_DIR

set -euo pipefail

# ── argument parsing ─────────────────────────────────────────────────────────
SRC_DIR="."
OUT_DIR=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --out-dir) OUT_DIR="$2"; shift 2 ;;
    -h|--help)
      sed -n '2,/^$/p' "$0" | grep '^#' | sed 's/^# \?//'
      exit 0
      ;;
    -*) echo "yjoin: unknown option: $1" >&2; exit 1 ;;
    *)  SRC_DIR="$1"; shift ;;
  esac
done

SRC_DIR="$(cd "${SRC_DIR}" && pwd)"
OUT_DIR="${OUT_DIR:-${SRC_DIR}}"
mkdir -p "${OUT_DIR}"

# ── helpers ──────────────────────────────────────────────────────────────────
render() {
  local f="$1"
  if [[ "${f}" == *.yaml++ ]]; then
    jq++ "${f}" | yq -y '.'
  else
    yq -y '.' "${f}"
  fi
}

strip_ext() {
  local base="$1"
  case "${base}" in
    *.yaml++) echo "${base%.yaml++}" ;;
    *.yaml)   echo "${base%.yaml}" ;;
    *)        echo "${base}" ;;
  esac
}

# ── grouped files: {stem}@{id}.yaml[++] ─────────────────────────────────────
declare -A stem_files  # stem -> newline-separated sorted file list

while IFS= read -r f; do
  [[ -z "${f}" ]] && continue
  name="$(strip_ext "$(basename "${f}")")"
  stem="${name%%@*}"
  stem_files["${stem}"]+="${f}"$'\n'
done < <(find "${SRC_DIR}" -maxdepth 1 \( -name "*@*.yaml++" -o -name "*@*.yaml" \) | sort)

for stem in "${!stem_files[@]}"; do
  out="${OUT_DIR}/${stem}.yaml"
  first=true
  {
    while IFS= read -r f; do
      [[ -z "${f}" ]] && continue
      [[ "${first}" == "true" ]] || printf -- "---\n"
      first=false
      render "${f}"
    done <<< "${stem_files[${stem}]}"
  } > "${out}"
  echo "Generated: ${out}"
done

# ── single-doc passthrough: {name}.yaml++ (no @) ────────────────────────────
while IFS= read -r f; do
  [[ -z "${f}" ]] && continue
  name="$(strip_ext "$(basename "${f}")")"
  out="${OUT_DIR}/${name}.yaml"
  render "${f}" > "${out}"
  echo "Generated: ${out}"
done < <(find "${SRC_DIR}" -maxdepth 1 -name "*.yaml++" ! -name "*@*" | sort)
